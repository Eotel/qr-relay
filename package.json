{
  "name": "qr-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @qr-relay/server dev",
    "dev:client": "pnpm --filter @qr-relay/client dev",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@11.1.1"
}
