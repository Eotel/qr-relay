{
  "name": "qr-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @qr-relay/server dev",
    "dev:client": "pnpm --filter @qr-relay/client dev",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check .",
    "lint:md": "pnpm remark:check && pnpm textlint",
    "remark": "remark . --output --quiet",
    "remark:check": "remark . --frail --quiet",
    "textlint": "textlint \"**/*.md\"",
    "textlint:fix": "textlint --fix \"**/*.md\"",
    "secretlint": "secretlint --maskSecrets \"**/*\"",
    "prepare": "lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "lefthook": "^2.1.8",
    "remark": "^15.0.1",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-lint": "^10.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "remark-preset-lint-recommended": "^7.0.1",
    "remark-toc": "^9.0.0",
    "secretlint": "^13.0.2",
    "textlint": "^15.7.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@11.1.1",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "lefthook", "sharp", "workerd"]
  }
}
